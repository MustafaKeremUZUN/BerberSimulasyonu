@model IEnumerable<BerberSimulasyonu.Models.Customer>
@{
    ViewData["Title"] = "Müşteri Listesi";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Müşteri Listesi</h4>
            <a asp-action="Register" class="btn btn-light">Yeni Müşteri Ekle</a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-4">
                    <p class="text-muted">Kayıtlı müşteri bulunamadı.</p>
                    <a asp-action="Register" class="btn btn-primary">İlk Müşteriyi Ekle</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Ad Soyad</th>
                                <th>Telefon</th>
                                <th>E-posta</th>
                                <th>Kayıt Tarihi</th>
                                <th>Ziyaret Sayısı</th>
                                <th>İndirim Durumu</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in Model)
                            {
                                <tr>
                                    <td><strong>@customer.FullName</strong></td>
                                    <td>@customer.PhoneNumber</td>
                                    <td>@customer.Email ?? "-"</td>
                                    <td>@customer.CreatedDate.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <span class="badge @(customer.VisitCount >= 31 ? "bg-success" : customer.VisitCount >= 11 ? "bg-warning" : "bg-secondary")">
                                            @customer.VisitCount
                                        </span>
                                    </td>
                                    <td>
                                        @if (customer.VisitCount >= 31)
                                        {
                                            <span class="text-success">%20 indirim</span>
                                        }
                                        else if (customer.VisitCount >= 11)
                                        {
                                            <span class="text-warning">%10 indirim</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">İndirim yok</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@customer.Id" class="btn btn-sm btn-info">Detay</a>
                                            <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-sm btn-warning">Düzenle</a>
                                            <a asp-controller="Appointment" asp-action="Create" asp-route-customerId="@customer.Id" class="btn btn-sm btn-success">Randevu</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
