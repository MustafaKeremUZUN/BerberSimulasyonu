@model IEnumerable<BerberSimulasyonu.Models.Employee>
@{
    ViewData["Title"] = "Çalışanlar";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Çalışanlar</h4>
                    <a asp-action="Create" class="btn btn-light">
                        <i class="fas fa-plus"></i> Yeni Çalışan
                    </a>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Ad Soyad</th>
                                    <th>Pozisyon</th>
                                    <th>Telefon</th>
                                    <th>E-posta</th>
                                    <th>İşe Başlama</th>
                                    <th>Saatlik Ücret</th>
                                    <th>Durum</th>
                                    <th class="text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@employee.FullName</strong>
                                            @if (!employee.IsActive)
                                            {
                                                <span class="badge bg-secondary ms-2">Pasif</span>
                                            }
                                        </td>
                                        <td>@employee.Position</td>
                                        <td>@employee.PhoneNumber</td>
                                        <td>@employee.Email</td>
                                        <td>@employee.HireDate.ToString("dd.MM.yyyy")</td>
                                        <td>@employee.HourlyRate.ToString("C")</td>
                                        <td>
                                            @if (employee.IsActive)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Pasif</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a asp-action="Details" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a asp-action="Schedule" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-info">
                                                    <i class="fas fa-calendar"></i>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-warning">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
