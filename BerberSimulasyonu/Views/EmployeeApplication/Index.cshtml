@model IEnumerable<BerberSimulasyonu.Models.EmployeeApplication>
@{
    ViewData["Title"] = "Başvurular";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">📋 İş Başvuruları</h4>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Yeni Başvuru
                    </a>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle"></i> Henüz başvuru bulunmuyor.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Başvuran</th>
                                        <th>İletişim</th>
                                        <th>Pozisyon</th>
                                        <th>Ücret Beklentisi</th>
                                        <th>Quiz Sonucu</th>
                                        <th>Başvuru Tarihi</th>
                                        <th>Durum</th>
                                        <th class="text-center">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var application in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@application.FullName</strong><br>
                                                <small class="text-muted">@application.Experience</small>
                                            </td>
                                            <td>
                                                <div><i class="fas fa-phone"></i> @application.PhoneNumber</div>
                                                @if (!string.IsNullOrEmpty(application.Email))
                                                {
                                                    <div><i class="fas fa-envelope"></i> @application.Email</div>
                                                }
                                            </td>
                                            <td>@application.DesiredPosition</td>
                                            <td>@application.DesiredHourlyRate.ToString("C")</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <span class="badge @(application.CorrectAnswers >= 3 ? "bg-success" : "bg-danger") me-2">
                                                        @application.CorrectAnswers/@application.TotalQuestions
                                                    </span>
                                                    <small class="text-muted">(@application.QuizScore.ToString("F1")%)</small>
                                                </div>
                                            </td>
                                            <td>@application.ApplicationDate.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td>
                                                @switch (application.Status)
                                                {
                                                    case ApplicationStatus.Pending:
                                                        <span class="badge bg-warning">Beklemede</span>
                                                        break;
                                                    case ApplicationStatus.Approved:
                                                        <span class="badge bg-success">Onaylandı</span>
                                                        break;
                                                    case ApplicationStatus.Rejected:
                                                        <span class="badge bg-danger">Reddedildi</span>
                                                        break;
                                                    case ApplicationStatus.Withdrawn:
                                                        <span class="badge bg-secondary">Çekildi</span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@application.Id" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    @if (application.Status == ApplicationStatus.Pending)
                                                    {
                                                        <a asp-action="Approve" asp-route-id="@application.Id" class="btn btn-sm btn-outline-success">
                                                            <i class="fas fa-check"></i>
                                                        </a>
                                                        <a asp-action="Reject" asp-route-id="@application.Id" class="btn btn-sm btn-outline-danger">
                                                            <i class="fas fa-times"></i>
                                                        </a>
                                                    }
                                                    <a asp-action="Delete" asp-route-id="@application.Id" class="btn btn-sm btn-outline-secondary">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
