@model BerberSimulasyonu.Models.Appointment
@{
    ViewData["Title"] = "Yeni Randevu";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Yeni Randevu Oluştur</h4>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="CustomerId" class="form-label">Müşteri</label>
                                    <select asp-for="CustomerId" class="form-select" id="customerSelect">
                                        <option value="">Müşteri Seçin...</option>
                                        @foreach (var customer in ViewBag.Customers)
                                        {
                                            <option value="@customer.Id" data-visit-count="@customer.VisitCount">
                                                @customer.FullName (@customer.PhoneNumber) - Ziyaret: @customer.VisitCount
                                            </option>
                                        }
                                    </select>
                                    <span asp-validation-for="CustomerId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ServiceId" class="form-label">Hizmet</label>
                                    <div class="row" id="serviceGrid">
                                        @foreach (var service in ViewBag.Services)
                                        {
                                            <div class="col-md-6 mb-3">
                                                <div class="card service-card @(service.Category == "Saç" ? "hair-service" : "beard-service")" data-service-id="@service.Id" data-price="@service.Price" data-category="@service.Category">
                                                    <div class="row g-0">
                                                        <div class="col-md-4">
                                                            <img src="@service.ImageUrl" class="img-fluid rounded-start" alt="@service.Name" style="height: 120px; object-fit: cover;">
                                                        </div>
                                                        <div class="col-md-8">
                                                            <div class="card-body">
                                                                <h6 class="card-title">@service.Name</h6>
                                                                <p class="card-text small">@service.Description</p>
                                                                <p class="card-text">
                                                                    <strong>@service.Price.ToString("C")</strong>
                                                                    <span class="badge bg-secondary ms-2">@service.Category</span>
                                                                </p>
                                                                <div class="form-check">
                                                                    <input class="form-check-input service-radio" type="radio" name="serviceRadio" value="@service.Id" id="service_@service.Id">
                                                                    <label class="form-check-label" for="service_@service.Id">Seç</label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <input type="hidden" asp-for="ServiceId" id="serviceSelect" />
                                    <span asp-validation-for="ServiceId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="AppointmentDate" class="form-label">Randevu Tarihi</label>
                                    <input asp-for="AppointmentDate" class="form-control" type="datetime-local" />
                                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Fiyat Hesaplaması</label>
                                    <div class="card bg-light">
                                        <div class="card-body py-2">
                                            <div class="d-flex justify-content-between">
                                                <span>Orijinal Fiyat:</span>
                                                <span id="originalPrice">-</span>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                <span>İndirim:</span>
                                                <span id="discount">-</span>
                                            </div>
                                            <hr class="my-1">
                                            <div class="d-flex justify-content-between">
                                                <strong>Final Fiyat:</strong>
                                                <strong id="finalPrice">-</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label">Notlar (Opsiyonel)</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="List" class="btn btn-secondary">Listeye Dön</a>
                            <button type="submit" class="btn btn-success">Randevu Oluştur</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <style>
        .service-card {
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }
        
        .service-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        
        .service-card.selected {
            border-color: #0d6efd;
            background-color: #f8f9fa;
        }
        
        .hair-service {
            border-left: 4px solid #6f42c1;
        }
        
        .beard-service {
            border-left: 4px solid #fd7e14;
        }
        
        .service-radio {
            display: none;
        }
        
        .service-card.selected .service-radio + .form-check-label {
            color: #0d6efd;
            font-weight: bold;
        }
    </style>
    <script>
        $(document).ready(function() {
            function calculatePrice() {
                var customerId = $('#customerSelect').val();
                var serviceId = $('#serviceSelect').val();
                
                if (customerId && serviceId) {
                    var customerOption = $('#customerSelect option:selected');
                    var serviceCard = $('.service-card[data-service-id="' + serviceId + '"]');
                    var visitCount = parseInt(customerOption.data('visit-count'));
                    var originalPrice = parseFloat(serviceCard.data('price'));
                    
                    var discountPercentage = 0;
                    if (visitCount >= 31) {
                        discountPercentage = 20;
                    } else if (visitCount >= 11) {
                        discountPercentage = 10;
                    }
                    
                    var discountAmount = originalPrice * (discountPercentage / 100);
                    var finalPrice = originalPrice - discountAmount;
                    
                    $('#originalPrice').text('₺' + originalPrice.toFixed(2));
                    $('#discount').text('%' + discountPercentage + ' (₺' + discountAmount.toFixed(2) + ')');
                    $('#finalPrice').text('₺' + finalPrice.toFixed(2));
                    
                    if (discountPercentage > 0) {
                        $('#discount').addClass('text-success');
                        $('#finalPrice').addClass('text-success');
                    } else {
                        $('#discount').removeClass('text-success');
                        $('#finalPrice').removeClass('text-success');
                    }
                } else {
                    $('#originalPrice').text('-');
                    $('#discount').text('-');
                    $('#finalPrice').text('-');
                }
            }
            
            // Handle service card selection
            $('.service-card').click(function() {
                $('.service-card').removeClass('selected');
                $(this).addClass('selected');
                var serviceId = $(this).data('service-id');
                $('#serviceSelect').val(serviceId);
                $(this).find('.service-radio').prop('checked', true);
                calculatePrice();
            });
            
            // Handle radio button changes
            $('.service-radio').change(function() {
                $('.service-card').removeClass('selected');
                $(this).closest('.service-card').addClass('selected');
                var serviceId = $(this).val();
                $('#serviceSelect').val(serviceId);
                calculatePrice();
            });
            
            $('#customerSelect').change(calculatePrice);
            
            // Set default datetime to current time
            var now = new Date();
            now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
            $('#AppointmentDate').val(now.toISOString().slice(0,16));
        });
    </script>
}
