@model IEnumerable<BerberSimulasyonu.Models.Appointment>
@{
    ViewData["Title"] = "Randevu Listesi";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Randevu Listesi</h4>
            <a asp-action="Create" class="btn btn-light">Yeni Randevu</a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-4">
                    <p class="text-muted">Kayıtlı randevu bulunamadı.</p>
                    <a asp-action="Create" class="btn btn-success">İlk Randevuyu Oluştur</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Müşteri</th>
                                <th>Hizmet</th>
                                <th>Orijinal Fiyat</th>
                                <th>İndirim</th>
                                <th>Final Fiyat</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appointment in Model)
                            {
                                <tr>
                                    <td>@appointment.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <strong>@appointment.Customer.FullName</strong><br>
                                        <small class="text-muted">@appointment.Customer.PhoneNumber</small>
                                    </td>
                                    <td>
                                        @appointment.Service.Name<br>
                                        <small class="text-muted">@appointment.Service.Category</small>
                                    </td>
                                    <td>@appointment.OriginalPrice.ToString("C")</td>
                                    <td>
                                        @if (appointment.DiscountPercentage > 0)
                                        {
                                            <span class="text-success">%@appointment.DiscountPercentage</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Yok</span>
                                        }
                                    </td>
                                    <td><strong class="text-success">@appointment.FinalPrice.ToString("C")</strong></td>
                                    <td>
                                        @if (appointment.IsCompleted)
                                        {
                                            <span class="badge bg-success">Tamamlandı</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Beklemede</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@appointment.Id" class="btn btn-sm btn-info">Detay</a>
                                            @if (!appointment.IsCompleted)
                                            {
                                                <form asp-action="Complete" asp-route-id="@appointment.Id" method="post" style="display: inline;">
                                                    <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Randevuyu tamamlandı olarak işaretlemek istediğinize emin misiniz?')">
                                                        Tamamla
                                                    </button>
                                                </form>
                                            }
                                            <a asp-action="Delete" asp-route-id="@appointment.Id" class="btn btn-sm btn-danger">Sil</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
